# ============================================
# Keil MDK-ARM 编译中间文件
# ============================================

# 目标文件
*.o

# 依赖文件
*.d
*.dep

# 交叉引用文件
*.crf

# 链接器输入文件
*.lnp

# ARM 可执行文件 (体积大)
*.axf

# 编译报告 HTML
*.htm
*.build_log.htm

# Hex / Bin 输出 (编译产物，可从源码重新生成)
*.hex
*.bin

# ============================================
# Keil MDK 工程内部输出目录
# ============================================

# 编译过程输出 (每个工程下的同名子目录)
**/MDK-ARM/*/
**/MDK-ARM/DebugConfig/
**/MDK-ARM/RTE/

# 列表文件和目标文件目录 (Keil 默认输出路径)
Listings/
listings/
Objects/
objects/

# ============================================
# Keil MDK 用户/IDE 临时文件
# ============================================

# 用户 GUI 配置文件 (包含本地路径和窗口位置)
*.uvguix.*

# J-Link / ST-Link 调试设置
*.jlink
JLinkLog.txt
JLinkSettings.ini

# CMSIS 配置向导备份
*.uvprojx.bak

# ============================================
# VS Code 临时文件
# ============================================

# Keil Assistant 插件日志和工作区缓存
.vscode/keil-assistant.log
.vscode/.cache/

# ============================================
# 操作系统生成文件
# ============================================

# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store
